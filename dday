<div class="widget-card">
    <div class="title">/ᐠ - ˕ -マ Ⳋ ૮₍ ᓀ ‸ ᓂ ₎ა</div>
    
    <!-- 👇 여기에 원하는 이미지 주소(URL)를 넣으세요 -->
    <img class="widget-image" src="https://lh3.googleusercontent.com/d/1lHBPI9UxbW_Q3qNjujv5cMxiN_KSkZQL" alt="위젯 이미지">
    
    <div id="dday-text" class="dday-count">Calculating...</div>
    <div class="target-date">2026. 5. 9.</div>
</div>

<style>
    body {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        background-color: transparent;
        display: flex;
        justify-content: center;
        align-items: center;
        height: 100vh;
        margin: 0;
    }
    .widget-card {
        background: #ffffff;
        border: 1px solid rgba(15, 15, 15, 0.1);
        box-shadow: 0px 4px 12px rgba(0, 0, 0, 0.05);
        border-radius: 16px;
        padding: 25px 10px;
        text-align: center;
        min-width: 250px;
    }
    .title {
        font-size: 11px;
        font-weight: 500;
        margin-bottom: 12px;
    }
    .widget-image {
        display: block;
        max-width: 250px;       
        max-height: 250px;      
        width: auto;
        height: auto;
        margin: 0 auto px auto; 
        border-radius: 8px;     
    }
    .dday-count {
        font-size: 35px;
        font-weight: 800;
        color: #bacede;
    }
    .target-date {
        font-size: 11px;
        color: #bacede;
        margin-top: 10px;
    }
</style>

<script>
    const target = new Date(2026, 4, 9);
    const now = new Date();
    const today = new Date(now.getFullYear(), now.getMonth(), now.getDate());
    const diffTime = today.getTime() - target.getTime();
    const diffDays = Math.floor(diffTime / (1000 * 60 * 60 * 24));
    const displayElement = document.getElementById('dday-text');
    
    if (diffDays === 0) {
        displayElement.innerText = "D+1"; // 공백 제거
        displayElement.style.color = "#bacede";
    } else if (diffDays > 0) {
        displayElement.innerText = "D+" + (diffDays + 1); // 공백 제거
        displayElement.style.color = "#bacede";
    } else {
        displayElement.innerText = "D" + diffDays; // 이전 날짜도 공백 제거 (예: D-35)
    }
</script>
